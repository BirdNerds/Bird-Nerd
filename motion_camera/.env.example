# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored - never commit it.

# Path to your Firebase service account key JSON file.
# Use a path relative to the motion_camera/ directory.
FIREBASE_CREDENTIALS_PATH=./.credentials/bird-nerd-firebase-adminsdk.json

# Your Firebase Storage bucket name.
# Found in Firebase Console -> Storage, shown as gs://your-project-id.firebasestorage.app
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
